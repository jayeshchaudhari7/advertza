# ============================================
# Advertza Backend — Environment Variables
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to version control.
# ============================================

# MongoDB connection URI
# Example: mongodb+srv://username:password@cluster.mongodb.net/advertza
MONGODB_URI=mongodb://localhost:27017/advertza

# JWT secret for admin authentication (use a strong random string)
JWT_SECRET=your-super-secret-jwt-key-change-this

# Server port
PORT=5000

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Google Sheets integration (optional)
GOOGLE_SHEET_ID=your-google-sheet-id
